{
  "name": "@ohara/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "db:setup": "bun run src/db/setup.ts",
    "db:push": "bun run src/db/setup.ts && drizzle-kit push",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "webhook:proxy": "./scripts/webhook-proxy.sh"
  },
  "dependencies": {
    "@ohara/shared": "workspace:*",
    "@elysiajs/cors": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-auth": "^1.2.9",
    "bullmq": "^5.34.8",
    "drizzle-orm": "^0.41.0",
    "elysia": "^1.2.12",
    "glob": "^11.0.1",
    "gray-matter": "^4.0.3",
    "postgres": "^3.4.5",
    "pino": "^9.6.0",
    "simple-git": "^3.27.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@ohara/config": "workspace:*",
    "@types/bun": "^1.2.4",
    "drizzle-kit": "^0.31.4",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.7.3"
  }
}
